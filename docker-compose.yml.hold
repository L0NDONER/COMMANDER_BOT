services:
  commander:
    build: .
    restart: unless-stopped
    # 20 bots created from one blueprint
    deploy:
      replicas: 1
    volumes:
      # These must be absolute or relative to this folder
      - ./stars.db:/app/stars.db
      - ./cache.db:/app/cache.db
      - ./credentials.py:/app/credentials.py
      - ./services/ebay:/app/services/ebay
      - /var/www/html/feed:/var/www/html/feed
    environment:
      - PYTHONUNBUFFERED=1
      - ADMIN_CHAT_ID=5811891036
